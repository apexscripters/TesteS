            else cExpr=cExpr:sub(1,-2) end; cShow()
        elseif val=="=" then
            if cExpr~="" then
                local r=cEval(cExpr)
                cResult=r or "Erro"; cLast=r~=nil
                if r then addHist("Calc: "..cExpr.." = "..r) end
                cShow()
            end
        elseif val=="MC" then cMem=0
        elseif val=="MR" then
            if cLast then cExpr="";cResult="";cLast=false end
            cExpr=cExpr..tostring(cMem); cShow()
        elseif val=="M+" then
            local v=tonumber(cResult~="" and cResult or cExpr)
            if v then cMem=cMem+v end
        else
            if cLast then
                cExpr=OPS[val] and (cResult..val) or val
                cResult=""; cLast=false
            else cExpr=cExpr..val end
            cShow()
        end
    end)
