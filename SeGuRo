local locCache = {}
local function getLocalizacao(player)
    if locCache[player.UserId] then
        local d = locCache[player.UserId]
        return d.pais, d.estado, d.cod
    end
    local cod, pais, estado = "??", T.desc, T.desc
    pcall(function()
        local r = LS:GetCountryRegionForPlayerAsync(player)
        if r and r ~= "" then
            cod = r
            pais = PAISES[r] or r
        end
    end)
    if ESTADOS[cod] then
        local lst = ESTADOS[cod]
        estado = lst[math.random(1, #lst)]
    end
    locCache[player.UserId] = {pais=pais, estado=estado, cod=cod}
    return pais, estado, cod
end

