--Estadisticas y Cronometro
local function formatNumber(v)
    return tostring(v):reverse():gsub("%d%d%d", "%1,"):reverse():gsub("^,", "")
end

local function updateKills()
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    if leaderstats and leaderstats:FindFirstChild("Kills") then
        local k = leaderstats.Kills.Value
        local formattedExact = formatNumber(k)
        local formattedK = string.format("%.1f", k / 1000)
        killsLabel.Text = formattedExact .. " (" .. formattedK .. "K)"
    end
end
updateKills()
task.spawn(function()
    local leaderstats = LocalPlayer:WaitForChild("leaderstats", 10)
    if leaderstats and leaderstats:FindFirstChild("Kills") then
        leaderstats.Kills.Changed:Connect(updateKills)
    end
end)

