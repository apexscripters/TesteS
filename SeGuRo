local function cEval(e)
    local s=e:gsub("÷","/"):gsub("×","*")
        :gsub("π",tostring(math.pi))
        :gsub("√%((.-)%)",function(x) return "math.sqrt("..x..")" end)
        :gsub("sin%((.-)%)",function(x) return "math.sin(math.rad("..x.."))" end)
        :gsub("cos%((.-)%)",function(x) return "math.cos(math.rad("..x.."))" end)
        :gsub("tan%((.-)%)",function(x) return "math.tan(math.rad("..x.."))" end)
        :gsub("log%((.-)%)",function(x) return "math.log("..x..")" end)
        :gsub("abs%((.-)%)",function(x) return "math.abs("..x..")" end)
        :gsub("(%d+)!",function(n)
            local v=tonumber(n) or 0; local r=1
            for i=2,math.min(v,20) do r=r*i end
            return r
        end)
    local fn=loadstring("return "..s)
    if not fn then return nil end
    local ok2,r=pcall(fn)
    if not ok2 then return nil end
    if type(r)=="number" then
        if r~=r then return "NaN" end
        if r==math.huge then return "∞" end
        return string.format("%.10g",r)
    end
    return tostring(r)
end

