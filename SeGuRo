-- Enviar mensagem: APENAS para o chat interno, sem tocar no chat do jogo
local function enviarMensagem()
    local msg=chatInput.Text:match("^%s*(.-)%s*$")
    if msg=="" then return end
    -- Exibe localmente
    chatDispatch(meuNome, msg, true)
    -- Envia para outros jogadores do mesmo server com prefixo secreto
    -- usando pcall para não quebrar se o jogo bloquear
    pcall(function()
        local ss=LP:FindFirstChild("SayMessageRequest") or
                 game:GetService("ReplicatedStorage"):FindFirstChild("SayMessageRequest") or
                 game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents") and
                 game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents:FindFirstChild("SayMessageRequest")
        if ss then
            ss:FireServer("__MF__"..meuNome..": "..msg, "All")
        end
    end)
    chatInput.Text=""
    addHist("Chat: msg enviada")
end

chatEnvBtn.MouseButton1Click:Connect(enviarMensagem)
