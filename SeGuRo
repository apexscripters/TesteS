--Optimizacion de Rendimiento y Ocultacion de Interfaz
local function cleanPart(v)
    if v:IsA("BasePart") or v:IsA("MeshPart") or v:IsA("UnionOperation") then
        v.Material = Enum.Material.Plastic
        v.Reflectance = 0
        v.CastShadow = false
    elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Sparkles") then
        v.Enabled = false
    elseif v:IsA("Decal") or v:IsA("Texture") then
        v.Transparency = 1
    end
end

local function optimizePerformance()
    Settings.Rendering.QualityLevel = Enum.QualityLevel.Level01
    Lighting.GlobalShadows = false
    Lighting.Brightness = 0.5
    Lighting.ClockTime = 5.5
    Lighting.EnvironmentDiffuseScale = 0
    Lighting.EnvironmentSpecularScale = 0
    if Lighting:FindFirstChild("Sky") then Lighting.Sky:Destroy() end
    for _, v in pairs(Workspace:GetDescendants()) do cleanPart(v) end
end
