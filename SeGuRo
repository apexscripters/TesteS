-- ══════ ESP ══════
local espAura,espName,espRain=false,false,false
local espCor=COR_DEF
local espObjs={}
task.spawn(function()
    local t=0
    while true do
        espCor=espRain and Color3.fromHSV(t,1,1) or COR_DEF
        t=(t+0.01)%1; task.wait(0.03)
    end
end)
local function remESP()
    for _,o in ipairs(espObjs) do pcall(function() o:Destroy() end) end
    espObjs={}
end
RunService.RenderStepped:Connect(function()
    if not espAura and not espName then remESP(); return end
    for i=#espObjs,1,-1 do
        if not espObjs[i] or not espObjs[i].Parent then table.remove(espObjs,i) end
    end
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LP and p.Character then
            local chr=p.Character; local hrp=chr:FindFirstChild("HumanoidRootPart")
            if hrp then
                local hl=chr:FindFirstChild("_MFESP")
                if espAura then
                    if not hl then
                        hl=Instance.new("Highlight"); hl.Name="_MFESP"
                        hl.FillTransparency=0.6; hl.OutlineTransparency=0
                        hl.Parent=chr; table.insert(espObjs,hl)
                    end
                    hl.FillColor=espCor; hl.OutlineColor=espCor
                else if hl then hl:Destroy() end end
                local bb=hrp:FindFirstChild("_MFESPName")
                if espName then
                    local lbl2
                    if not bb then
                        bb=Instance.new("BillboardGui"); bb.Name="_MFESPName"
                        bb.Size=U2(0,200,0,50); bb.AlwaysOnTop=true
                        bb.StudsOffset=Vector3.new(0,3.5,0); bb.Parent=hrp
                        table.insert(espObjs,bb)
                        lbl2=Instance.new("TextLabel",bb)
                        lbl2.Size=U2(1,0,1,0); lbl2.BackgroundTransparency=1
                        lbl2.Font=Enum.Font.GothamBold; lbl2.TextSize=14
                    else lbl2=bb:FindFirstChildOfClass("TextLabel") end
                    if lbl2 then
                        lbl2.Text=p.DisplayName.."\n(@"..p.Name..")"
                        lbl2.TextColor3=espCor
                    end
                else if bb then bb:Destroy() end end
            end
        end
    end
end)

