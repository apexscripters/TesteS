local FLY_ON_COR=C3(65,22,145); local FLY_OFF_COR=C3(20,16,38)

local function pararFly()
    flyOn=false
    for _,c in pairs(flyConns) do pcall(function() c:Disconnect() end) end
    flyConns={}
    local char=LP.Character
    if char then
        local hrp=char:FindFirstChild("HumanoidRootPart")
        if hrp then
            for _,d in ipairs(hrp:GetChildren()) do
                if d.Name=="_FBV" or d.Name=="_FBG" then d:Destroy() end
            end
        end
        local hum=char:FindFirstChildOfClass("Humanoid")
        if hum then hum.PlatformStand=false end
    end
    flyTogBtn.Text="🦅 "..T.ligar.." FLY"
    flyTogBtn.BackgroundColor3=FLY_OFF_COR
    addHist("Fly OFF")
end

local function iniciarFly()
    local char=LP.Character or LP.CharacterAdded:Wait()
    local hrp=char:WaitForChild("HumanoidRootPart",5)
    local hum=char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    flyOn=true; hum.PlatformStand=true
    for _,d in ipairs(hrp:GetChildren()) do
        if d.Name=="_FBV" or d.Name=="_FBG" then d:Destroy() end
    end
    local bv=Instance.new("BodyVelocity",hrp)
    bv.Name="_FBV"; bv.MaxForce=Vector3.new(1e9,1e9,1e9); bv.Velocity=Vector3.zero
    local bg=Instance.new("BodyGyro",hrp)
    bg.Name="_FBG"; bg.MaxTorque=Vector3.new(9e9,9e9,9e9); bg.P=9000; bg.D=200; bg.CFrame=hrp.CFrame
    flyTogBtn.Text="🦅 "..T.desligar.." FLY"
    flyTogBtn.BackgroundColor3=FLY_ON_COR
    addHist("Fly ON v="..flySpd)
    local keys={}
    table.insert(flyConns,UIS.InputBegan:Connect(function(i,gp)
        if not gp then keys[i.KeyCode.Name]=true end
    end))
    table.insert(flyConns,UIS.InputEnded:Connect(function(i)
        keys[i.KeyCode.Name]=nil
    end))
    table.insert(flyConns,RunService.Heartbeat:Connect(function()
        if not flyOn or not hrp or not hrp.Parent then return end
        local mv=Vector3.zero; local cam=CAM.CFrame
        if keys["W"] then mv=mv+cam.LookVector end
        if keys["S"] then mv=mv-cam.LookVector end
        if keys["A"] then mv=mv-cam.RightVector end
        if keys["D"] then mv=mv+cam.RightVector end
        if keys["E"] or keys["Space"] then mv=mv+Vector3.new(0,1,0) end
        if keys["Q"] or keys["LeftControl"] then mv=mv-Vector3.new(0,1,0) end
        local spd=flySpd*(keys["LeftShift"] and 3 or 1)
        bv.Velocity=mv.Magnitude>0.01 and mv.Unit*spd or bv.Velocity*0.82
        bg.CFrame=CFrame.new(hrp.Position,hrp.Position+Vector3.new(cam.LookVector.X,0,cam.LookVector.Z))
    end))
end
flyTogBtn.MouseButton1Click:Connect(function()
    if flyOn then pararFly() else iniciarFly() end
end)
LP.CharacterAdded:Connect(function() if flyOn then task.wait(1); pararFly() end end)

