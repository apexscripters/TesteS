-- Usa BindableEvent para comunicação local dentro do mesmo cliente
-- Para multi-jogador no mesmo server, usa PlayerChatted mas FILTRA
-- e mostra APENAS na janela interna, nunca envia ao chat do jogo
local chatMensagens = {}
local chatOrdem = 0
local chatCallbacks = {}

local function chatRegistrarCallback(fn)
    table.insert(chatCallbacks, fn)
end

local function chatDispatch(nome, msg, minha)
    chatOrdem = chatOrdem + 1
    local entry = {
        ordem = chatOrdem,
        hora  = os.date("%H:%M"),
        nome  = nome,
        msg   = msg,
        minha = minha,
    }
    table.insert(chatMensagens, entry)
    if #chatMensagens > 100 then table.remove(chatMensagens, 1) end
    for _, cb in ipairs(chatCallbacks) do
        pcall(cb, entry)
    end
end

-- Ouvir mensagens de outros jogadores do mesmo servidor
-- Usa o evento Chatted MAS não envia nada ao chat do jogo
local function conectarChatJogador(p)
    p.Chatted:Connect(function(msg)
        -- Apenas mensagens com prefixo secreto do nosso script
        if msg:sub(1, 6) == "__MF__" then
            chatDispatch(p.DisplayName, msg:sub(7), false)
        end
    end)
end
for _, p in ipairs(Players:GetPlayers()) do
    if p ~= LP then conectarChatJogador(p) end
end
