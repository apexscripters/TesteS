local function mkFrame(parent, size, pos, bg, trans)
    local f = Instance.new("Frame", parent)
    f.Size = size; f.Position = pos or U2(0,0,0,0)
    f.BackgroundColor3 = bg or COR_BG
    f.BackgroundTransparency = trans or 0
    f.BorderSizePixel = 0
    return f
end

local function mkLabel(parent, txt, size, pos, fs, font, cor, xa, yw)
    local l = Instance.new("TextLabel", parent)
    l.Size = size; l.Position = pos or U2(0,0,0,0)
    l.Text = txt; l.TextSize = fs or 11
    l.Font = font or Enum.Font.Gotham
    l.TextColor3 = cor or COR_TXT
    l.BackgroundTransparency = 1
    l.TextXAlignment = xa or Enum.TextXAlignment.Left
    l.TextWrapped = yw or false
    return l
end

local function mkBtn(parent, txt, size, pos, bg, fs, tcor)
    local COR_ORIG = bg or COR_BTN
    local b = Instance.new("TextButton", parent)
    b.Size = size; b.Position = pos or U2(0,0,0,0)
    b.Text = txt; b.TextSize = fs or 11
    b.Font = Enum.Font.GothamBold
    b.TextColor3 = tcor or COR_TXT
    b.BackgroundColor3 = COR_ORIG
    b.BorderSizePixel = 0
    b.AutoButtonColor = false
    arred(b, 7)
    b.MouseEnter:Connect(function()
        b.BackgroundColor3 = C3(
            math.min(255, COR_ORIG.R*255+20),
            math.min(255, COR_ORIG.G*255+20),
            math.min(255, COR_ORIG.B*255+20))
    end)
    b.MouseLeave:Connect(function() b.BackgroundColor3 = COR_ORIG end)
    return b
end

local function mkScroll(parent, size, pos)
    local s = Instance.new("ScrollingFrame", parent)
    s.Size = size; s.Position = pos or U2(0,0,0,0)
    s.BackgroundTransparency = 1
    s.ScrollBarThickness = 3
    s.CanvasSize = U2(0,0,0,0)
    s.ScrollBarImageColor3 = COR_DEF
    s.BorderSizePixel = 0
    return s
end

-- Arrasto universal
local function addDrag(janela, handle)
    handle = handle or janela
    local drag, di, ds, sp = false
    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then
            drag=true; ds=i.Position; sp=janela.Position
            i.Changed:Connect(function()
                if i.UserInputState == Enum.UserInputState.End then drag=false end
            end)
        end
    end)
    handle.InputChanged:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseMovement
        or i.UserInputType == Enum.UserInputType.Touch then di=i end
    end)
    UIS.InputChanged:Connect(function(i)
        if i==di and drag then
            local d = i.Position - ds
            janela.Position = U2(sp.X.Scale, sp.X.Offset+d.X, sp.Y.Scale, sp.Y.Offset+d.Y)
        end
    end)
end

